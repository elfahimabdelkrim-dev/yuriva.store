# ============================================================
# YURIVA — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ─── Supabase (optional — site works without Supabase in static mode) ───────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── WhatsApp (customer store button) ───────────────────────────────────────
# Format: 212XXXXXXXXX (no + sign, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=212666648564

# ─── WhatsApp Admin Order Notifications (server-side only) ───────────────────
# Set WHATSAPP_NOTIFY_ENABLED=true to activate. Tokens are NEVER exposed to frontend.
WHATSAPP_NOTIFY_ENABLED=false
# Provider: cloud_api (Meta WhatsApp Cloud API) | webhook (Make/n8n/Zapier)
WHATSAPP_PROVIDER=cloud_api
# Admin phone to receive notifications — format: 212XXXXXXXXX (no +)
WHATSAPP_ADMIN_PHONE=212666648564

# ── Cloud API credentials (required when WHATSAPP_PROVIDER=cloud_api) ────────
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Approved template name and language code (required for business-initiated msgs)
WHATSAPP_TEMPLATE_NAME=order_notification_admin
WHATSAPP_TEMPLATE_LANGUAGE=ar
# Set to true ONLY for WhatsApp sandbox/test numbers — bypasses template requirement
WHATSAPP_USE_TEXT=false

# ── Webhook credentials (required when WHATSAPP_PROVIDER=webhook) ────────────
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=

# ── Admin API protection (optional) ──────────────────────────────────────────
ADMIN_SECRET=

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yuriva.ma

# ─── Tracking Pixels (optional) ─────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=4569111183412330
# Second Meta Pixel — both receive ALL events (PageView, ViewContent, Purchase, etc.)
NEXT_PUBLIC_META_PIXEL_ID_2=1162700877684124
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your-tiktok-pixel-id
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX

# ─── Google Sheets (optional, server-side only) ──────────────────────────────
# NEVER expose these in NEXT_PUBLIC_ variables
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
